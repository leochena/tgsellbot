# .env.example
# SECURITY WARNING: Never commit real credentials to version control!
# Copy this file to .env and fill with actual values

# === TELEGRAM CONFIGURATION ===
# Get from @BotFather
TOKEN=your_bot_token_here
# Your Telegram user ID (get from @userinfobot)
OWNER_ID=123456789
# Optional HTTP proxy for Telegram Bot API, for example http://127.0.0.1:7890
BOT_PROXY_URL=

# === PAYMENT CONFIGURATION ===
# Telegram Payments provider token for Stripe/card checkout (optional)
# Create/connect the payment provider in BotFather, then paste the provider token here.
TELEGRAM_PROVIDER_TOKEN=

# CryptoPay API token (optional)
# Get from: https://t.me/send
CRYPTO_PAY_TOKEN=

# Telegram Stars configuration
# Price of 1 unit of your currency in stars (0 to disable)
STARS_PER_VALUE=0.91

# Currency for payments (3-letter code: RUB, USD, EUR, etc.)
PAY_CURRENCY=RUB

# Internal balance unit shown to users. Keep PAY_CURRENCY as a valid provider currency.
BALANCE_CURRENCY=UStars

# Referral system percentage (0-100, 0 to disable)
REFERRAL_PERCENT=0

# Payment timeout in seconds
PAYMENT_TIME=1800

# Payment limits
MIN_AMOUNT=20
MAX_AMOUNT=10000

# === LINKS & UI CONFIGURATION ===
# Telegram channel for notifications (optional)
# Format: @channelname or https://t.me/channelname
CHANNEL_URL=

# Telegram channel ID
# Get from: @get_id_bot
CHANNEL_ID=

# Target group/channel for admin announcements. Prefer numeric -100... chat id.
# Leave empty to reuse CHANNEL_ID or CHANNEL_URL.
ANNOUNCEMENT_CHAT_ID=

# Support user ID (optional)
HELPER_ID=

# Bot rules text (optional)
RULES="1. Be respectful\n2. No spam\n3. Follow Telegram ToS"

# === LOCALIZATION & LOGGING ===
# Bot language (ru or en)
BOT_LOCALE=ru

# Log files paths
BOT_LOGFILE=logs/bot.log
BOT_AUDITFILE=logs/audit.log

# Logging configuration (1 to enable, 0 to disable)
LOG_TO_STDOUT=1
LOG_TO_FILE=1
DEBUG=0

# Enable/disable the review system (1 = enabled, 0 = disabled)
REVIEWS_ENABLED=1

# === ENGAGEMENT: CHECK-IN & LOTTERY ===
# Daily points reward for check-in. Legacy CHECKIN_REWARD_AMOUNT is still read as a fallback.
CHECKIN_POINTS_REWARD=1
# Tickets awarded to the current active lottery when a user checks in
CHECKIN_TICKETS_PER_DAY=1
# Points awarded to inviter after an invited user joins the configured group and checks in
GROUP_INVITE_REWARD_POINTS=1

# === REDIS CONFIGURATION ===
# Set to 0 to disable Redis entirely (bot will use in-memory storage)
# When disabled, FSM states are lost on restart and caching is disabled
REDIS_ENABLED=1
# For FSM storage and caching
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# Set password if Redis requires authentication
REDIS_PASSWORD=

# === DATABASE CONFIGURATION ===
# PostgreSQL settings
POSTGRES_DB=telegram_shop
POSTGRES_USER=shop_user
# SECURITY: Use strong password!
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=change_me_to_strong_password
# POSTGRES_HOST is automatically set to 'db' in Docker environment
POSTGRES_HOST=localhost
DB_PORT=5432
# PostgreSQL schema. Keep public for a dedicated database; use a custom schema
# when sharing a local PostgreSQL instance for development.
POSTGRES_SCHEMA=public

# === WEB ADMIN PANEL ===
# Set to 0 for bot-only production deployments that must not start /admin or /client.
WEB_ADMIN_ENABLED=1
# Set to 1 to serve only /platform/app, /platform/api, public reports, and /health
# without exposing SQLAdmin. Useful behind a HTTPS reverse proxy for Telegram Mini App.
PLATFORM_WEB_ENABLED=0
ADMIN_HOST=localhost
ADMIN_PORT=9090
# Optional override for platform-only web serving; defaults to ADMIN_HOST/ADMIN_PORT.
PLATFORM_WEB_HOST=localhost
PLATFORM_WEB_PORT=9090
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
# SECURITY: Change in production. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
# How long the local admin login cookie is kept.
ADMIN_SESSION_MAX_AGE_DAYS=30

# === WEBHOOK MODE (optional) ===
# Set WEBHOOK_ENABLED=1 to use webhook instead of polling
WEBHOOK_ENABLED=0
# Public URL for webhook (e.g., https://yourdomain.com)
WEBHOOK_URL=
# Path for webhook endpoint
WEBHOOK_PATH=/webhook
# Secret token for webhook verification
WEBHOOK_SECRET=

# === AUTO-CLEANUP ===
# Days to keep audit log entries (0 to disable)
AUDIT_RETENTION_DAYS=90
# Days to keep pending/failed payments (0 to disable)
PAYMENTS_RETENTION_DAYS=90

# === DOCKER PERMISSIONS (Linux only) ===
# Set these to match your host user's UID/GID on Linux
# Run 'id' command on your host to find your UID/GID
# Default: 1000 (common for first non-root user on Linux)
# Only needed if you get permission errors on logs/ or data/ directories
# PUID=1000
# PGID=1000
